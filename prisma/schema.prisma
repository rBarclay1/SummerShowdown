generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider     = "sqlite"
  relationMode = "prisma"
}

model Athlete {
  id                Int                      @id @default(autoincrement())
  name              String                   @unique
  clerkId           String?                  @unique
  entries           PREntry[]
  posts             Post[]
  comments          Comment[]
  pushSubscriptions PushSubscription[]
  notificationPrefs NotificationPreferences?
  createdAt         DateTime                 @default(now())
}

model Lift {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  type         String        @default("lift")
  unit         String        @default("lbs")
  isTotalLoad  Boolean       @default(false)
  entries      PREntry[]
  leaderboards Leaderboard[] @relation("BoardLift")
  createdAt    DateTime      @default(now())
}

model Leaderboard {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  mainLiftId Int
  endDate    DateTime?
  mainLift   Lift      @relation("BoardLift", fields: [mainLiftId], references: [id])
  entries    PREntry[]
  createdAt  DateTime  @default(now())

  @@index([mainLiftId])
}

model PREntry {
  id            Int         @id @default(autoincrement())
  athleteId     Int
  liftId        Int
  leaderboardId Int
  weightLbs     Float
  date          DateTime    @default(now())
  athlete       Athlete     @relation(fields: [athleteId], references: [id])
  lift          Lift        @relation(fields: [liftId], references: [id])
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([athleteId])
  @@index([liftId])
  @@index([leaderboardId])
  @@index([date])
}

model Post {
  id        Int       @id @default(autoincrement())
  authorId  Int
  author    Athlete   @relation(fields: [authorId], references: [id])
  content   String
  imageData String?
  comments  Comment[]
  createdAt DateTime  @default(now())

  @@index([authorId])
  @@index([createdAt])
}

model Comment {
  id          Int      @id @default(autoincrement())
  postId      Int
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    Int
  author      Athlete  @relation(fields: [authorId], references: [id])
  content     String
  authorToken String
  createdAt   DateTime @default(now())

  @@index([postId])
  @@index([authorId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  athleteId Int
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([athleteId])
}

model NotificationPreferences {
  id           Int      @id @default(autoincrement())
  athleteId    Int      @unique
  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)
  email        String?
  createdAt    DateTime @default(now())
}
